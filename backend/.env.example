# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/workhive

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
FRONTEND_URL=http://localhost:5173

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=25

# SendGrid (optional)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@workhive.com

# App
APP_NAME=WorkHive
APP_URL=http://localhost:8000
