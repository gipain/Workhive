# WorkHive — Environment Variables
# Copy this file to .env and fill in all values before running.

# ──────────────────────────────
# Database
# ──────────────────────────────
DATABASE_URL=postgresql://workhive:CHANGE_ME_DB_PASSWORD@db:5432/workhive

# ──────────────────────────────
# Security
# ──────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_STRONG_RANDOM_SECRET_KEY_32_CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ──────────────────────────────
# Application URLs
# ──────────────────────────────
# Public URL of your frontend (used for CORS and reset-password links)
FRONTEND_URL=https://your-domain.com
# Public URL of this backend (used in emails, optional)
APP_URL=https://api.your-domain.com

# ──────────────────────────────
# File Uploads
# ──────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=25

# ──────────────────────────────
# Email (optional — for sending reset tokens by email)
# If not configured, reset tokens are returned in the API response.
# ──────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@your-domain.com

# ──────────────────────────────
# Postgres (used by the db service in docker-compose.prod.yml)
# ──────────────────────────────
POSTGRES_USER=workhive
POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
POSTGRES_DB=workhive
